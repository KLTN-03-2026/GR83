PORT=4000
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
# Server-side Google key: use a non-referrer-restricted key for backend requests.
GOOGLE_MAPS_SERVER_API_KEY=your-google-maps-server-api-key
# Google OAuth Web Client ID (can be one ID or comma-separated list of accepted audiences)
GOOGLE_AUTH_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Gemini API for assistant chatbot
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_MS=9000

# SMTP config for signup verification email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
# Keep true for production. Set false only in local networks with SSL inspection/proxy.
SMTP_TLS_REJECT_UNAUTHORIZED=true
SMTP_USER=your-gmail@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=SmartRide
SMTP_FROM_EMAIL=your-gmail@gmail.com

# Signup OTP settings
SIGNUP_OTP_EXPIRES_MINUTES=10
SIGNUP_OTP_RESEND_COOLDOWN_SECONDS=60
SIGNUP_OTP_MAX_VERIFY_ATTEMPTS=5

# Google password-change bootstrap token
GOOGLE_PASSWORD_TOKEN_EXPIRES_MINUTES=10

# MoMo payment integration
# Real integration requires Partner Code / Access Key / Secret Key issued by MoMo M4B.
# For local demo without M4B account, set MOMO_MOCK_MODE=true and keep keys empty.
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_CREATE_ORDER_URL=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_QUERY_ORDER_URL=https://test-payment.momo.vn/v2/gateway/api/query
MOMO_CALLBACK_URL=http://localhost:4000/api/rides/payments/momo/callback
MOMO_REDIRECT_URL=http://localhost:5173/
MOMO_REQUEST_TYPE=captureWallet
MOMO_MOCK_MODE=true

